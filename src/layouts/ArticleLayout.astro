---
import BaseLayout from './BaseLayout.astro';
import SideBar from '../components/SideBar.astro';
export interface Props {
  title: string;
  description?: string;
  pubDate: string;
  category: string;
  affiliate?: {label: string; url: string; description?: string}[];
  type?: string;
}
const { title, description, pubDate, category, affiliate, type } = Astro.props;

const MOSHIMO_RAKUTENBOOKS_AID = '5584862';
const MOSHIMO_RAKUTEN_AID = '5584857';

function rakutenBooksLink(url: string) {
  return `https://af.moshimo.com/af/c/click?a_id=${MOSHIMO_RAKUTENBOOKS_AID}&p_id=56&pc_id=56&pl_id=637&url=${encodeURIComponent(url)}`;
}

const BOOKS: Record<string, {title: string; author: string; desc: string; url: string}[]> = {
  '投資・NISA': [
    { title: '改訂版 お金の大学', author: '両@リベ大', desc: '新NISA対応。NISA・保険・副業をわかりやすく解説。会社員の入門書。', url: 'https://books.rakuten.co.jp/rb/18041936/' },
    { title: 'ジェイソン流お金の増やし方 改訂版', author: '厚切りジェイソン', desc: '新NISA対応。米国インデックス投資をシンプルに解説。初心者向け。', url: 'https://books.rakuten.co.jp/rb/17970148/' },
    { title: '敗者のゲーム（原著第8版）', author: 'チャールズ・エリス', desc: 'インデックス投資の名著。長期・分散・低コストの本質を解説。', url: 'https://books.rakuten.co.jp/rb/16973485/' },
    { title: '株式投資の未来', author: 'ジェレミー・シーゲル', desc: '長期保有で配当再投資が最強である根拠を豊富なデータで解説。', url: 'https://books.rakuten.co.jp/rb/3689555/' },
    { title: 'インデックス投資は勝者のゲーム', author: 'ジョン・C・ボーグル', desc: 'バンガード創設者が説く低コスト投資哲学。NISA民必読。', url: 'https://books.rakuten.co.jp/rb/15489998/' },
    { title: '新NISAはこの9本から選びなさい', author: '中野晴啓', desc: '6000本超の投資信託から厳選した9本を解説。銘柄選びの基準が明快。', url: 'https://books.rakuten.co.jp/rb/17640860/' },
  ],
  '副業': [
    { title: '毎月10万円をAIに稼いでもらう！ChatGPT副業の教科書', author: 'ChatGPTビジネス研究会', desc: 'AIを活用して副収入を得る具体的な手順を解説。会社員向け。', url: 'https://books.rakuten.co.jp/rb/17531420/' },
    { title: '転職2.0', author: '村上臣', desc: 'LinkedIn日本代表が教える副業・転職時代のキャリア戦略。', url: 'https://books.rakuten.co.jp/rb/16535816/' },
    { title: 'お金も知識も自信もない私に、稼げる副業を教えてください！！', author: '宮中清貴', desc: '初心者が副業で稼ぐための入門書。具体的な手順で解説。', url: 'https://books.rakuten.co.jp/rb/17537929/' },
    { title: 'ゼロから稼げるChatGPT入門', author: '加納敏彦', desc: '副業・ビジネスで稼ぐためのChatGPT活用術を職種別に解説。', url: 'https://books.rakuten.co.jp/rb/17726737/' },
  ],
  'AI活用': [
    { title: '会社で使えるChatGPT', author: 'マスクド・アナライズ', desc: '個人業務からチーム導入まで、ChatGPT活用を1冊で完全理解。', url: 'https://books.rakuten.co.jp/rb/17939620/' },
    { title: 'ChatGPTを使い尽くす！深津式プロンプト読本', author: '深津貴之', desc: 'ビジネスシーンで使えるプロンプト設計を実践的に解説。', url: 'https://books.rakuten.co.jp/rb/17953362/' },
    { title: 'ChatGPT最強の仕事術', author: '池田朋弘', desc: '日常業務にChatGPTを組み込む実践的テクニックを解説。', url: 'https://books.rakuten.co.jp/rb/17550641/' },
    { title: 'ChatGPTと最新AIツールがまるごとわかる本', author: '', desc: 'ChatGPTから最新AIツールまで、使い方を網羅した入門書。', url: 'https://books.rakuten.co.jp/rb/18066430/' },
  ],
  'お金の基本': [
    { title: '改訂版 お金の大学', author: '両@リベ大', desc: '家計・保険・投資の基本をすべて学べる一冊。新NISA対応。', url: 'https://books.rakuten.co.jp/rb/18041936/' },
    { title: '難しいことはわかりませんが、お金の増やし方を教えてください！', author: '山崎元', desc: '投資初心者のバイブル。対話形式でわかりやすい。', url: 'https://books.rakuten.co.jp/rb/13468386/' },
    { title: '改訂版 金持ち父さん貧乏父さん', author: 'ロバート・キヨサキ', desc: 'お金の教育の重要性と資産形成の考え方を学ぶ世界的ベストセラー。', url: 'https://books.rakuten.co.jp/rb/12488205/' },
    { title: 'となりの億万長者〔新版〕', author: 'トマス・J・スタンリー', desc: '普通の会社員が億を築く生活習慣と思考法を研究した名著。', url: 'https://books.rakuten.co.jp/rb/12402860/' },
    { title: 'バビロンの大富豪', author: 'ジョージ・S・クレイソン', desc: '古代バビロンを舞台にお金の本質を寓話で解説。長く読まれる古典。', url: 'https://books.rakuten.co.jp/rb/5817140/' },
  ],
  '節約': [
    { title: '貯金はこれでつくれます', author: '節約オタクふゆこ', desc: '本当にお金が増える46のコツ。実践的な貯金術を解説。', url: 'https://books.rakuten.co.jp/rb/17717104/' },
    { title: '手取り17万円からの貯金の教科書', author: '横山光昭（監修）', desc: 'イラストでわかる、低収入でも実践できる節約・貯金術。', url: 'https://books.rakuten.co.jp/rb/14620066/' },
    { title: 'はじめての人のための3000円投資生活', author: '横山光昭', desc: '節約した3000円から始める積立投資の入門書。55万部超のベストセラー。', url: 'https://books.rakuten.co.jp/rb/14304056/' },
    { title: '図解 年収200万円からの貯金生活宣言', author: '横山光昭', desc: '低収入でも着実に貯金できる家計改善の全手順。', url: 'https://books.rakuten.co.jp/rb/12600757/' },
  ],
  '思考法': [
    { title: 'サイコロジー・オブ・マネー', author: 'モーガン・ハウセル', desc: 'お金に関する行動心理を20の法則で解説した世界的ベストセラー。', url: 'https://books.rakuten.co.jp/rb/16915229/' },
    { title: '嫌われる勇気', author: '岸見一郎・古賀史健', desc: 'アドラー心理学で「他者の目を気にしない自分軸」を構築する。', url: 'https://books.rakuten.co.jp/rb/12570589/' },
    { title: '反応しない練習', author: '草薙龍瞬', desc: 'ムダな感情を手放して合理的に行動する思考法。お金にも応用できる。', url: 'https://books.rakuten.co.jp/rb/13315854/' },
    { title: 'となりの億万長者〔新版〕', author: 'トマス・J・スタンリー', desc: '普通の会社員が億を築く習慣と思考法を調査した名著。', url: 'https://books.rakuten.co.jp/rb/12402860/' },
  ],
};

// pubDateの日付（1〜31）を使って表示する2冊をローテーション
function selectBooks(allBooks: {title: string; author: string; desc: string; url: string}[], seed: number) {
  if (allBooks.length <= 2) return allBooks;
  const idx = seed % allBooks.length;
  const first = allBooks[idx];
  const second = allBooks[(idx + 1) % allBooks.length];
  return [first, second];
}

const seedDay = pubDate ? parseInt(pubDate.split('-')[2] ?? '1', 10) : 1;
const allBooks = BOOKS[category] ?? BOOKS['お金の基本'];
const books = selectBooks(allBooks, seedDay);

const pageUrl = Astro.url.href;
const xShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(pageUrl)}&via=okusokumoney`;
const hatenaUrl = `https://b.hatena.ne.jp/entry/s/${pageUrl.replace(/^https?:\/\//, '')}`;
---
<BaseLayout title={title} description={description} noindex={type === 'news'}>
  <Fragment slot="sidebar">
    <SideBar />
  </Fragment>

  <article>
    <!-- パンくず -->
    <p style="font-size:0.8rem;color:#888;margin-bottom:12px;">
      <a href="/" style="color:#888;">トップ</a> &rsaquo;
      <a href={`/category/${encodeURIComponent(category)}/`} style="color:#888;">{category}</a> &rsaquo;
      <span>{title.length > 30 ? title.slice(0, 30) + '…' : title}</span>
    </p>

    <div style="background:#fff;border-radius:8px;padding:24px;border:1px solid #e0e0e0;">
      <div style="margin-bottom:16px;">
        <span style="font-size:0.78rem;color:#888;">{pubDate.slice(0, 10).replace(/-/g, '.')}</span>
        <h1 style="font-size:1.4rem;font-weight:700;line-height:1.5;margin-top:6px;">{title}</h1>
      </div>

      <!-- シェアボタン -->
      <div class="share-buttons">
        <a href={xShareUrl} target="_blank" rel="noopener" class="share-btn share-x">X でシェア</a>
        <a href={hatenaUrl} target="_blank" rel="noopener" class="share-btn share-hatena">はてブ</a>
      </div>

      <!-- ADSENSE_ARTICLE_TOP -->

      <div class="article-body">
        <slot />
      </div>

      <!-- ADSENSE_ARTICLE_BOTTOM -->

      <!-- アフィリエイトCTA -->
      {affiliate?.filter(a => !a.url.startsWith('AFFILIATE_')).map(a => (
        <div class="affiliate-box">
          <p style="font-size:0.72rem;color:#888;margin-bottom:6px;">※広告・アフィリエイトリンクを含みます</p>
          <p style="font-weight:700;font-size:0.95rem;margin-bottom:4px;">{a.label}</p>
          {a.description && <p style="font-size:0.85rem;color:#555;margin-bottom:8px;">{a.description}</p>}
          <a href={a.url} target="_blank" rel="noopener sponsored" class="btn">詳しく見る →</a>
        </div>
      ))}

      <!-- 記事末シェアボタン -->
      <div class="share-buttons" style="margin-top:24px;">
        <span style="font-size:0.85rem;font-weight:700;color:#555;">この記事をシェア：</span>
        <a href={xShareUrl} target="_blank" rel="noopener" class="share-btn share-x">X でシェア</a>
        <a href={hatenaUrl} target="_blank" rel="noopener" class="share-btn share-hatena">はてブに追加</a>
      </div>

      <!-- おすすめ書籍 -->
      <div style="margin:32px 0 0;">
        <h2 style="font-size:1rem;font-weight:700;margin-bottom:12px;padding:8px 12px;background:#f5f5f5;border-left:4px solid #0a1628;">この記事に関連するおすすめ書籍</h2>
        <p style="font-size:0.72rem;color:#888;margin-bottom:10px;">※本ページはアフィリエイト広告を含みます</p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          {books.map(book => (
            <a href={rakutenBooksLink(book.url)} target="_blank" rel="noopener sponsored"
              style="display:flex;gap:14px;background:#fafafa;border:1px solid #e8e8e8;border-radius:8px;padding:14px;text-decoration:none;color:#1a1a1a;">
              <div style="flex:1;">
                <p style="font-size:0.7rem;color:#bf0000;font-weight:700;margin-bottom:3px;">📚 楽天ブックス</p>
                <p style="font-weight:700;font-size:0.9rem;margin-bottom:4px;">{book.title}{book.author ? `（${book.author}）` : ''}</p>
                <p style="font-size:0.8rem;color:#555;margin-bottom:6px;">{book.desc}</p>
                <p style="font-size:0.78rem;color:#bf0000;font-weight:700;">楽天ブックスで見る →</p>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- コメント欄（Waline） -->
      <div style="margin-top:32px;">
        <h2 style="font-size:1rem;font-weight:700;margin-bottom:16px;padding:8px 12px;background:#f5f5f5;border-left:4px solid #0a1628;">コメント</h2>
        <div id="waline"></div>
      </div>

      <link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />
      <style>
        #waline .waline-container { display: flex; flex-direction: column; }
        #waline .wl-editor-wrapper { order: 2; margin-top: 16px; }
        #waline .wl-comment-wrapper { order: 1; }
      </style>
      <script is:inline>
        (function() {
          var s = document.createElement('script');
          s.type = 'module';
          s.innerHTML = `
            import { init } from 'https://unpkg.com/@waline/client@v3/dist/waline.js';
            init({
              el: '#waline',
              serverURL: 'https://okusoku-waline.vercel.app',
              lang: 'ja',
              pageview: true,
              comment: true,
              login: 'disable',
              meta: ['nick', 'mail'],
              requiredMeta: [],
              placeholder: 'コメントを入力してください（匿名OK）',
            });
          `;
          document.currentScript
            ? document.currentScript.parentNode.insertBefore(s, document.currentScript)
            : document.head.appendChild(s);
        })();
      </script>
    </div>
  </article>
</BaseLayout>

<style>
  .article-body { line-height: 1.85; }
  :global(.article-body h2) { font-size: 1.2rem; font-weight: 700; margin: 2rem 0 1rem; padding: 10px 14px; background: #f5f5f5; border-left: 4px solid #0a1628; }
  :global(.article-body h3) { font-size: 1.05rem; font-weight: 700; margin: 1.5rem 0 0.5rem; border-bottom: 1px solid #e0e0e0; padding-bottom: 4px; }
  :global(.article-body p) { margin-bottom: 1rem; }
  :global(.article-body ul), :global(.article-body ol) { margin: 1rem 0 1rem 1.5rem; }
  :global(.article-body li) { margin-bottom: 0.4rem; }
  :global(.article-body strong) { font-weight: 700; }
  :global(.article-body table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.92rem; }
  :global(.article-body th) { background: #0a1628; color: #fff; padding: 10px 12px; text-align: left; border: 1px solid #1e3a6e; }
  :global(.article-body td) { padding: 10px 12px; border: 1px solid #ccc; }
  :global(.article-body tr:nth-child(even) td) { background: #f8f8f8; }
  .affiliate-box { background: #f0f8ff; border: 2px solid #0a1628; border-radius: 10px; padding: 20px; margin: 2rem 0; }
  .affiliate-box .btn { display: inline-block; background: #e44; color: #fff; padding: 10px 24px; border-radius: 6px; font-weight: 700; text-decoration: none; margin-top: 10px; }
  .share-buttons { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin: 16px 0; }
  .share-btn { display: inline-block; padding: 7px 16px; border-radius: 4px; font-size: 0.82rem; font-weight: 700; text-decoration: none; }
  .share-x { background: #000; color: #fff; }
  .share-x:hover { background: #333; }
  .share-hatena { background: #00a4de; color: #fff; }
  .share-hatena:hover { background: #0086b8; }
</style>
