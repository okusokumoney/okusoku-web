---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Pagination from '../../../components/Pagination.astro';
import SideBar from '../../../components/SideBar.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const PAGE_SIZE = 20;
  const allArticles = await getCollection('articles');
  const categories = ['投資・NISA', '副業', 'AI活用', 'お金の基本', '節約', '思考法'];

  return categories.map(category => {
    const filtered = allArticles
      .filter(a => a.data.category === category && a.data.type !== 'news')
      .sort((a, b) => { const d = new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(); return d !== 0 ? d : b.slug.localeCompare(a.slug); });
    const totalPages = Math.ceil(filtered.length / PAGE_SIZE);
    const articles = filtered.slice(0, PAGE_SIZE);
    return {
      params: { category },
      props: { articles, totalPages, category, total: filtered.length },
    };
  });
}

const { articles, totalPages, category, total } = Astro.props;

const CATEGORY_DESC: Record<string, string> = {
  '投資・NISA': '新NISAの活用法からインデックス投資の基礎まで、会社員が資産形成を始めるための情報をわかりやすく解説します。',
  '副業': '会社員が無理なく始められる副業の選び方・進め方・稼ぎ方を、実践的な視点から紹介します。',
  'AI活用': 'ChatGPTをはじめとするAIツールを仕事・副業・日常で活用する具体的な方法を解説します。',
  'お金の基本': '家計管理・保険・税金・銀行選びなど、会社員が知っておくべきお金の基礎知識をまとめています。',
  '節約': '無理なく続けられる節約術・固定費削減・ポイント活用など、手取りを増やす実践的な方法を紹介します。',
  '思考法': 'お金・副業・キャリアで成果を出すための考え方・習慣・マインドセットを解説します。',
};
const desc = CATEGORY_DESC[category] ?? '';
---
<BaseLayout title={`${category}の記事一覧`} description={desc}>
  <Fragment slot="sidebar">
    <SideBar />
  </Fragment>

  <div class="page-header">
    <h1>{category}</h1>
    <p class="article-count">全{total}件</p>
  </div>
  {desc && <p class="category-desc">{desc}</p>}

  <div class="article-list">
    {articles.map((a: any) => (
      <ArticleCard
        title={a.data.title}
        slug={a.slug}
        category={a.data.category}
        pubDate={a.data.pubDate}
        description={a.data.description}
        image={a.data.image}
        type={a.data.type}
      />
    ))}
  </div>

  {totalPages > 1 && (
    <Pagination currentPage={1} totalPages={totalPages} baseUrl={`/category/${category}`} />
  )}
</BaseLayout>

<style>
  .page-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 3px solid #0a1628;
  }
  .page-header h1 { font-size: 1.1rem; font-weight: 700; }
  .article-count { font-size: 0.82rem; color: #888; }
  .article-list { display: flex; flex-direction: column; gap: 10px; }
  .category-desc { font-size: 0.88rem; color: #555; line-height: 1.75; margin-bottom: 16px; padding: 12px 16px; background: #f5f8ff; border-left: 3px solid #41c9b4; border-radius: 0 6px 6px 0; }
</style>
