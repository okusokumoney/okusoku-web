---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const articles = allArticles.sort((a, b) =>
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---
<BaseLayout title="記事一覧">
  <h1 style="font-size:1.5rem;font-weight:700;margin-bottom:24px;">記事一覧</h1>
  <div style="display:grid;gap:16px;">
    {articles.map(article => (
      <a href={`/articles/${article.slug}/`} style="background:#fff;border-radius:10px;padding:20px;text-decoration:none;color:#1a1a1a;box-shadow:0 2px 6px rgba(0,0,0,0.06);display:flex;gap:16px;align-items:flex-start;">
        <div style="flex:1;">
          <p style="font-size:0.75rem;color:#888;margin-bottom:6px;">{article.data.category} · {article.data.pubDate}</p>
          <h2 style="font-size:1rem;font-weight:700;line-height:1.4;">{article.data.title}</h2>
          {article.data.description && <p style="font-size:0.85rem;color:#666;margin-top:6px;">{article.data.description}</p>}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
