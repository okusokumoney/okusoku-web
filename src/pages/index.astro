---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';
import SideBar from '../components/SideBar.astro';
import { getCollection } from 'astro:content';

const PAGE_SIZE = 20;
const allArticles = await getCollection('articles', ({ data }) => data.draft !== true);
const filtered = allArticles.filter(a => a.data.type !== 'news');
const sorted = filtered.sort((a, b) => {
  const dateDiff = new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
  if (dateDiff !== 0) return dateDiff;
  return b.slug.localeCompare(a.slug);
});
const totalPages = Math.ceil(sorted.length / PAGE_SIZE);
const articles = sorted.slice(0, PAGE_SIZE);
---
<BaseLayout title="トップ">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "億速",
    "url": "https://okusoku.com",
    "description": "会社員のためのお金・副業・AI活用メディア",
    "publisher": {
      "@type": "Person",
      "name": "億速",
      "url": "https://okusoku.com/about/"
    }
  })} slot="head" />
  <Fragment slot="sidebar">
    <SideBar />
  </Fragment>

  <div class="site-intro">
    <p>億速は、お金の知識ゼロから始めた会社員が実際の体験をもとに発信する、お金・投資・副業メディアです。NISA・iDeCo・節約・AI副業など、会社員が今すぐ実践できる情報を毎日更新しています。</p>
  </div>

  <div class="page-header">
    <h1>最新記事</h1>
    <p class="article-count">全{sorted.length}件</p>
  </div>

  <div class="article-list">
    {articles.map(a => (
      <ArticleCard
        title={a.data.title}
        slug={a.slug}
        category={a.data.category}
        pubDate={a.data.pubDate}
        description={a.data.description}
        image={a.data.image}
        type={a.data.type}
      />
    ))}
  </div>

  {totalPages > 1 && (
    <Pagination currentPage={1} totalPages={totalPages} baseUrl="/" />
  )}
</BaseLayout>

<style>
  .page-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 3px solid #0a1628;
  }
  .page-header h1 { font-size: 1.1rem; font-weight: 700; }
  .article-count { font-size: 0.82rem; color: #888; }
  .article-list { display: flex; flex-direction: column; gap: 10px; }
  .site-intro { background: #f0f6ff; border-left: 4px solid #41c9b4; border-radius: 0 6px 6px 0; padding: 14px 18px; margin-bottom: 20px; font-size: 0.9rem; line-height: 1.8; color: #333; }
</style>
