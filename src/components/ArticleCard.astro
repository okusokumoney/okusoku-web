---
export interface Props {
  title: string;
  slug: string;
  category: string;
  pubDate: string;
  description?: string;
  image?: string;
}
const { title, slug, category, pubDate, description, image } = Astro.props;

const categoryColors: Record<string, string> = {
  '投資・NISA': '#1a5fb4',
  '副業':       '#2e7d32',
  'AI活用':     '#6a0dad',
  'お金の基本': '#e65100',
  '節約':       '#00695c',
  '思考法':     '#b71c1c',
};
const color = categoryColors[category] ?? '#555';
---
<a href={`/articles/${slug}/`} class="article-card">
  {image ? (
    <div class="card-thumb-wrap">
      <img src={image} alt={title} class="card-thumb" loading="lazy" />
    </div>
  ) : (
    <div class="card-category" style={`background:${color}`}>{category}</div>
  )}
  <div class="card-body">
    {image && <p class="card-cat-badge" style={`color:${color}`}>{category}</p>}
    <p class="card-title">{title}</p>
    {description && <p class="card-desc">{description}</p>}
    <p class="card-date">{pubDate}</p>
  </div>
</a>

<style>
  .article-card {
    display: flex;
    gap: 0;
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: #1a1a1a;
    transition: box-shadow 0.15s;
  }
  .article-card:hover { box-shadow: 0 3px 12px rgba(0,0,0,0.1); }
  .card-thumb-wrap {
    width: 200px;
    flex-shrink: 0;
    align-self: stretch;
  }
  .card-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card-category {
    writing-mode: vertical-rl;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 8px 6px;
    min-width: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .card-cat-badge {
    font-size: 0.72rem;
    font-weight: 700;
    margin-bottom: 3px;
  }
  .card-body {
    padding: 10px 14px;
    flex: 1;
    min-width: 0;
  }
  .card-title {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.5;
    margin-bottom: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-desc {
    font-size: 0.8rem;
    color: #666;
    margin-bottom: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-date { font-size: 0.75rem; color: #999; }
  @media (max-width: 500px) {
    .card-thumb-wrap { width: 110px; }
  }
</style>
